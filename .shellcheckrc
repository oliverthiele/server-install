# shellcheck configuration
# https://www.shellcheck.net/wiki/

# SC2154: Variable is referenced but not assigned.
# All scripts are sourced into a shared shell; variables defined in one file
# are intentionally used in others. Shellcheck cannot follow dynamic sourcing.
disable=SC2154

# SC1090/SC1091: Not following source with dynamic path.
# Source paths are constructed at runtime (e.g. "${SCRIPT_DIR}/lib/utils.sh").
disable=SC1090
disable=SC1091